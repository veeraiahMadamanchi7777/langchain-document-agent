# Application
APP_ENV=development
APP_NAME=langchain-document-agent
APP_VERSION=0.1.0
DEBUG=true

# Logging
LOG_LEVEL=DEBUG

# LLM
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Embeddings
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Store
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=documents

# Document Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,docx

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Retrieval
RETRIEVER_TOP_K=5
RETRIEVER_SCORE_THRESHOLD=0.5
